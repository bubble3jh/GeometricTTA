{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "model": "opusplan",
  "statusLine": {
    "type": "command",
    "command": "python3 .claude/statusline.py",
    "padding": 1
  },
  "permissions": {
    "defaultMode": "bypassPermissions",
    "allow": [
      "Bash(git status)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git show *)",
      "Bash(git branch *)",
      "Bash(git rev-parse *)",
      "Bash(git ls-tree *)",
      "Bash(git grep *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(grep *)",
      "Bash(rg *)",
      "Bash(pytest *)",
      "Bash(python -m pytest *)",
      "Bash(python3 -m pytest *)",
      "Bash(ruff *)",
      "Bash(make test)",
      "Bash(make lint)",
      "Bash(make check)",
      "Bash(python3 .claude/hooks/log_peek.py *)",
      "Bash(ssh *100.125.103.5*)",
      "Bash(rsync *100.125.103.5*)",
      "Bash(scp *100.125.103.5*)",
      "Read"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./secrets/**)",
      "Read(~/.ssh/**)",
      "Read(~/.aws/**)",
      "Read(~/.config/gcloud/**)",
      "Read(**/*id_rsa*)",
      "Bash(cat ./.env*)",
      "Bash(cat .env*)",
      "Bash(cat ./.env.*)",
      "Bash(cat .env.*)",
      "Bash(cat ./secrets/*)",
      "Bash(cat secrets/*)",
      "Bash(cat ~/.ssh/*)",
      "Bash(cat ~/.aws/*)",
      "Bash(cat ~/.config/gcloud/*)",
      "Bash(cat *id_rsa*)",
      "Bash(cat *.pem)",
      "Bash(cat *.key)",
      "Bash(curl *)",
      "Bash(wget *)",
      "Bash(rm -rf /)",
      "Bash(mkfs*)",
      "Bash(dd *)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 .claude/hooks/pretooluse_bash_guard.py"
          },
          {
            "type": "command",
            "command": "python3 .claude/hooks/notify.py",
            "env": {"CLAUDE_HOOK_EVENT": "PreToolUse"}
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 .claude/hooks/permission_request_router.py"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "python3 .claude/hooks/notify.py",
            "env": {"CLAUDE_HOOK_EVENT": "PostToolUse"}
          },
          {
            "type": "prompt",
            "model": "claude-opus-4-6",
            "timeout": 120,
            "statusMessage": "Opus self-critique...",
            "prompt": "You are a strict code reviewer. A file was just written or edited.\n\nTool input: $ARGUMENTS\n\nIf the file is source code (Python, shell, etc.) — NOT markdown, JSON, YAML, txt, or config — review for:\n1. Bugs: logic errors, off-by-one, incorrect variable usage, missing boundary checks, detach/attach issues, tensor device mismatches\n2. Critical improvements: wrong algorithm, incorrect assumptions, broken gradient flow\n\nIf no issues found, OR if the file is not source code: output nothing at all.\nIf issues found, output ONLY this JSON (no other text):\n{\"hookSpecificOutput\": {\"hookEventName\": \"PostToolUse\", \"additionalContext\": \"[OPUS CRITIC]\\n<concise bullet list of issues>\"}}"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 .claude/hooks/notify.py",
            "env": {"CLAUDE_HOOK_EVENT": "PostToolUse"}
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 .claude/hooks/stop_guard.py"
          }
        ]
      }
    ]
  }
}